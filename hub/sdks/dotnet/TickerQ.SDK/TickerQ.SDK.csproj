<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <IsPackable>true</IsPackable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>TickerQ.SDK</AssemblyName>
    <PackageId>TickerQ.SDK</PackageId>
    <Title>TickerQ SDK</Title>
    <Description>HTTP client and integration helpers for interacting with TickerQ scheduler and hub endpoints.</Description>
    <PackageTags>$(PackageTags);sdk;client;http;remote;api</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="TickerQ.Utilities" Version="$(Version)" />
    <PackageReference Include="Grpc.Net.Client" Version="2.76.0" />
    <PackageReference Include="Google.Protobuf" Version="3.31.1" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../shared/TickerQ.Grpc.Contracts/TickerQ.Grpc.Contracts.csproj" />
  </ItemGroup>

</Project>
